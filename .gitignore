# --- Compiled Binaries & Objects ---
*.o
*.obj
*.so
*.a
*.lib
*.dll
*.exe
bin/
lib/
logfile

# --- CMake & Build Directories ---
# Ignore the entire build folder where you run ninja
build/
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
Makefile
install_manifest.txt
compile_commands.json
*.ninja
*.ninja_deps
*.ninja_log

# --- IDEs & Editors ---
.vscode/
.idea/
!.cursor/
!.cursor/*
!.cursor/rules/
!.cursor/rules/**
!.cursor/skills-cursor/
*.swp
*.swo
*~
.clang-format
.clangd/
.cache/
.vscode/
.cursor-user-data/
.vscode-user-data/

# --- Debugging & Core Dumps ---
gmon.out
core
*.core
vgcore.*
*.dSYM/
PIPE

# --- Project Specific (Testserver / Wireshark) ---
# Ignore generated ASN.1 dissectors or temporary certs
run/
docs/
*.log
*.pcap
*.pcapng

# --- PostgreSQL Source Artifacts (if submoduled) ---
tmp_check/

#Frontend
# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
pnpm-store/

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

